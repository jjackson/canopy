public/assets/programs/

# Per-run generated artifacts — output.mp4 + explorer/ + .tmp/ are
# regenerated by `npm run render -- --run=<id>` and depend on cached
# audio + clip files outside git, so we keep them out of history.
programs/*/runs/*/output.mp4
programs/*/runs/*/explorer/
programs/*/runs/*/.tmp/
