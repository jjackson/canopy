        "options",
        "recommended",
        "class"
      ],
      "title": "Decision",
      "type": "object"
    },
    "Feature": {
      "description": "A single buildable, verifiable capability within a scene (DDD v3).",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "verify": {
          "title": "Verify",
          "type": "string"
        }
      },
      "required": [
        "id",
        "description",
        "verify"
      ],
      "title": "Feature",
      "type": "object"
    },
    "NarrationItem": {
      "description": "One scene's narration entry in a ReviewRequest (DDD v3).\n\nCarries the scene's story beat (``text``), its index (``scene``), its\nslug (``id``), and the list of concrete buildable features declared by\nthe spec's ``Scene.features[]``.",
      "properties": {
        "scene": {
          "title": "Scene",
          "type": "integer"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "features": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Feature"
          },
          "title": "Features",
          "type": "array"
        }
      },
      "required": [
        "scene",
        "id",
        "text"
      ],
      "title": "NarrationItem",
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "gate": {
      "title": "Gate",
      "type": "string"
    },
    "video": {
      "additionalProperties": true,
      "title": "Video",
      "type": "object"
    },
    "decisions": {
      "items": {
        "$ref": "#/$defs/Decision"
      },
      "title": "Decisions",
      "type": "array"
    },
    "narration": {
      "items": {
        "anyOf": [
          {
            "$ref": "#/$defs/NarrationItem"
          },
