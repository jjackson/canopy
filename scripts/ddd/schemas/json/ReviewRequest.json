          }
        ]
      },
      "title": "Narration",
      "type": "array"
    },
    "autonomous_audit": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Autonomous Audit",
      "type": "array"
    },
    "actionability": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Actionability"
    }
  },
  "required": [
    "run_id",
    "gate",
    "video",
    "decisions",
    "narration"
  ],
  "title": "ReviewRequest",
  "type": "object"
