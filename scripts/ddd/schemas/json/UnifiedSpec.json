        "kind": {
          "const": "hold",
          "title": "Kind",
          "type": "string"
        },
        "seconds": {
          "title": "Seconds",
          "type": "number"
        }
      },
      "required": [
        "kind",
        "seconds"
      ],
      "title": "HoldAction",
      "type": "object"
    },
    "HoverAction": {
      "additionalProperties": false,
      "description": "Glide the cursor onto ``target`` and rest. No click.\n\n``seconds`` overrides the default dwell \u2014 useful when the demo is\nshowing a tooltip or hover-revealed control that needs time to appear.",
      "properties": {
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "must_succeed": {
          "default": false,
