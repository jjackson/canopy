        "description",
        "verify"
      ],
      "title": "Feature",
      "type": "object"
    },
    "FillAction": {
      "additionalProperties": false,
      "description": "Focus a field (``target``) and type ``value`` character-by-character.\n\nTyping fires real ``input`` events \u2014 reactive form widgets that gate\nbuttons on debounced input (e.g. the bulk-create line counter) WILL\nreact to ``fill`` but won't react to a raw ``.value = ...`` setter.",
      "properties": {
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "must_succeed": {
          "default": false,
          "title": "Must Succeed",
          "type": "boolean"
        },
        "kind": {
          "const": "fill",
          "title": "Kind",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "target",
        "value"
      ],
      "title": "FillAction",
      "type": "object"
    },
    "GotoAction": {
      "additionalProperties": false,
      "description": "Navigate to a URL. ``target`` is the URL (absolute or path-relative).",
      "properties": {
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "must_succeed": {
          "default": false,
          "title": "Must Succeed",
          "type": "boolean"
        },
        "kind": {
