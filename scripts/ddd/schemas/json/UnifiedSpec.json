      "type": "object"
    },
    "HoldAction": {
      "additionalProperties": false,
      "description": "Dwell in place for ``seconds``.\n\nThe single-purpose pause: framing time after a layout, reading time\nafter a render, slack so the SSE stream finishes flushing.",
      "properties": {
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        },
        "must_succeed": {
