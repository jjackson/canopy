{
  "description": "The DDD converge lifecycle for one run (run_id), persisted as run_state.yaml.\n\nPhase milestones \u2014 who writes each ``phase`` value:\n\n  * CODE-set (written by a .py module as the run advances):\n      - ``judged``    \u2014 set by ``run_pipeline.assemble_run_state`` after the\n        dual-judge verdict is assembled.\n      - ``uploaded``  \u2014 set by ``upload.upload_run`` after the run package is\n        published to canopy-web (terminal).\n  * ORCHESTRATOR-ONLY milestones (NEVER written by .py \u2014 they label loop\n    stages the orchestrator narrates): ``phase0``, ``spec``, ``render``,\n    ``converged``. The default is ``phase0``; the Literal accepts them so an\n    orchestrator-authored run_state validates, but no module assigns them.\n  * ``promoted`` is a legacy READ-alias for ``uploaded`` \u2014 accepted on read so\n    older on-disk run_state.yaml files still validate; new runs write\n    ``uploaded`` (see ``upload.upload_run``, which treats both as published).",
  "properties": {
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "narrative_slug": {
      "title": "Narrative Slug",
      "type": "string"
    },
    "phase": {
      "default": "phase0",
      "enum": [
        "phase0",
        "spec",
        "render",
        "judged",
        "converged",
        "uploaded",
        "promoted"
      ],
      "title": "Phase",
      "type": "string"
    },
    "iteration": {
      "default": 0,
      "title": "Iteration",
      "type": "integer"
    },
    "why_brief": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Why Brief"
    },
    "verdicts": {
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "title": "Verdicts",
      "type": "object"
    },
    "findings": {
      "default": [],
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Findings",
      "type": "array"
    },
    "pending_review": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pending Review"
    },
    "last_actor": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Actor"
    },
    "last_actor_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Actor At"
    },
    "scenes_run": {
      "anyOf": [
        {
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scenes Run"
    },
    "scene_filter": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scene Filter"
    },
    "auto_iterate_next_action": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Auto Iterate Next Action"
    },
    "auto_iterate_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Auto Iterate Reason"
    },
    "iteration_decks": {
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "title": "Iteration Decks",
      "type": "object"
    },
    "iteration_clips": {
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "title": "Iteration Clips",
      "type": "object"
    },
    "score_history": {
      "default": [],
      "items": {
        "type": "number"
      },
      "title": "Score History",
      "type": "array"
    },
    "narrative_review_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Narrative Review Url"
    },
    "narrative_review_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Narrative Review Id"
    },
    "findings_review_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Findings Review Id"
    },
    "findings_review_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Findings Review Url"
    }
  },
  "required": [
    "run_id",
    "narrative_slug"
  ],
  "title": "RunState",
  "type": "object"
}